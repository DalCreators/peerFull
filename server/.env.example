# ── Server ───────────────────────────────────────────────────────────
PORT=3001

# Comma-separated list of allowed CORS origins
# In production: https://yourdomain.com
CLIENT_ORIGINS=*

# ── Database (Neon.tech) ──────────────────────────────────────────────
# Get this from https://console.neon.tech → your project → connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/codesync?sslmode=require

# ── Stripe ────────────────────────────────────────────────────────────
# From https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# From https://dashboard.stripe.com/webhooks (endpoint secret)
STRIPE_WEBHOOK_SECRET=whsec_...

# From https://dashboard.stripe.com/products (your Pro subscription price ID)
STRIPE_PRO_PRICE_ID=price_...

# ── Landing page URL (for Stripe redirect) ────────────────────────────
LANDING_URL=https://your-landing.vercel.app
